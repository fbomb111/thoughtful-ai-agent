# Azure Foundry Project
AZURE_AI_PROJECT_ENDPOINT=https://your-hub.services.ai.azure.com/api/projects/your-project

# Agent (set by setup_agent.py after provisioning)
THOUGHTFUL_AGENT_NAME=thoughtful-support
THOUGHTFUL_AGENT_VERSION=1

# AI Search (shared service for knowledge base)
AI_SEARCH_SERVICE_NAME=your-ai-search-service
AI_SEARCH_ADMIN_KEY=your-admin-key

# Azure OpenAI (for knowledge source embeddings + chat model)
AZURE_OPENAI_API_KEY=your-openai-key
OPENAI_RESOURCE_URI=https://your-hub.openai.azure.com

# Azure Subscription (for provisioning RemoteTool connection)
AZURE_SUBSCRIPTION_ID=your-subscription-id

# Managed Identity (optional - falls back to DefaultAzureCredential)
MANAGED_IDENTITY_CLIENT_ID=

# Storage Account (for knowledge base documents)
DOC_CHAT_STORAGE_ACCOUNT=your-storage-account

# Foundry Resource Group (for ARM API calls during provisioning)
FOUNDRY_RESOURCE_GROUP=your-resource-group
